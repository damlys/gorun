{
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  "files.associations": {
    "*.gotpl": "gotmpl",
    "*.yaml.gotpl": "helm",
    "*.yml.gotpl": "helm",

    "*.tf.tftpl": "terraform"
  },
  "files.readonlyInclude": {
    "**/*.gotpl.*": true,
    "**/*.tftpl.*": true
  }
}
